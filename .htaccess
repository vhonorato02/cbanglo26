# ============================================================
# Concurso de Bolsas — .htaccess da raiz do projeto
#
# Use este arquivo quando o projeto inteiro estiver dentro de
# public_html (cenário padrão da Hostinger quando o document root
# não pode ser apontado diretamente para a pasta public/).
#
# Ele encaminha todas as requisições para public/ e bloqueia o
# acesso direto às pastas internas (app, config, storage etc.).
# ============================================================

Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Bloqueia o acesso direto a pastas internas e arquivos sensíveis
    RewriteRule ^(app|bootstrap|config|database|routes|storage|tests|resources|tools|docs|vendor|node_modules|\.github)(/|$) - [F,L]
    RewriteRule ^(\.env|\.env\..*|composer\.(json|lock)|package(-lock)?\.json)$ - [F,L]

    # Evita reescrever novamente a rota interna public/.
    RewriteRule ^public(?:/|$) - [L]

    # Encaminha tudo para a pasta public/ sem expor esse prefixo na URL.
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

<FilesMatch "^\.">
    Require all denied
</FilesMatch>
