# Ambiente e segredos — NUNCA versionar
.env
.env.*
!.env.example
*.pem
*.key

# Dependências de desenvolvimento
node_modules/
vendor/

# Dados de runtime
storage/cache/*
!storage/cache/.gitkeep
storage/logs/*
!storage/logs/.gitkeep
database/*.sqlite
database/*.db

# Backups e dumps (podem conter dados pessoais)
*.sql.gz
*.bak
*.dump
dump*.sql
backup*/

# Sistema operacional / editor
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp

# Build temporário
*.log
.claude/
