# ==========================================================
# Concurso de Bolsas — Configuração de ambiente
# Copie este arquivo para ".env" e preencha os valores reais.
# O arquivo .env NUNCA deve ser versionado nem ficar acessível
# publicamente (o .htaccess já bloqueia o acesso via web).
# ==========================================================

# Ambiente: production | development
APP_ENV=production

# Exibir erros detalhados (somente em desenvolvimento!)
APP_DEBUG=false

# URL pública completa do site, sem barra final
APP_URL=https://agenciamd.com.br

# Fuso horário
APP_TIMEZONE=America/Sao_Paulo

# Chave da aplicação: string aleatória longa (mín. 32 caracteres).
# Gere uma em https://www.random.org/strings/ ou com:
# php -r "echo bin2hex(random_bytes(32));"
APP_KEY=

# Token de instalação: usado UMA vez para criar o primeiro
# administrador em /setup. Depois de criar o admin, apague
# esta linha ou deixe em branco para desativar a rota.
APP_SETUP_TOKEN=

# ----------------------------------------------------------
# Banco de dados MySQL/MariaDB (na Hostgator)
# ----------------------------------------------------------
DB_DRIVER=mysql
DB_HOST=agenciamd.com.br
DB_PORT=3306
DB_DATABASE=agenciam_cbanglo26
DB_USERNAME=agenciam_agenciamdcom
DB_PASSWORD=

# ----------------------------------------------------------
# E-mail (SMTP do cPanel ou provedor externo)
# Deixe SMTP_HOST vazio para desativar o envio de e-mails —
# as inscrições continuam funcionando normalmente.
# ----------------------------------------------------------
MAIL_FROM_ADDRESS=nao-responda@concursodebolsas.com.br
MAIL_FROM_NAME="Concurso de Bolsas"
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# tls (porta 587) | ssl (porta 465) | none
SMTP_ENCRYPTION=tls
